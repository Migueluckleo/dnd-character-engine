{
  "name": "dnd-character-engine",
  "version": "1.0.0",
  "description": "D&D 5e SRD Character Management Engine",
  "main": "dist/index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "preview:static": "python3 -m http.server 5500 --bind 127.0.0.1 --directory _site",
    "build": "tsc",
    "build:web": "vite build",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "deploy:migrate": "prisma migrate deploy",
    "render:build": "npm run prisma:generate && npm run build",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:watch": "jest --watch",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npm run prisma:generate && ts-node prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc --noEmit -p tsconfig.client.json",
    "security:check": "node scripts/security-check.js",
    "prepublish:check": "npm run typecheck && npm run typecheck:web && npm run test && npm run security:check"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.10.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^8.0.13"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
